{
  "manifest_version": 3,
  "name": "FinGuard AI: Real-time Fraud Radar",
  "version": "1.0.0",
  "description": "Scan financial news and stock pages for AI-driven risk signals and manipulation warnings.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.moneycontrol.com/*", "*://*.tickertape.in/*", "*://finance.yahoo.com/*"],
      "js": ["content.js"],
      "css": ["content-styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
