{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "frontend": {
      "source": "frontend",
      "healthcheck": "/",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
      }
    },
    "api-gateway": {
      "source": "api-gateway",
      "healthcheck": "/health",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
      }
    },
    "ai-engine": {
      "source": "ai-engine",
      "healthcheck": "/health",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
      }
    }
  }
}
